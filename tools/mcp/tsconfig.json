{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./",
    "rootDir": "./",
    "types": [
      "node"
    ]
  },
  "include": [
    "foundry-api-docs/src/**/*.ts",
    "foundry-types/src/**/*.ts"
  ]
}